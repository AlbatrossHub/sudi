<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_sudi_diamond" model="ir.ui.view">
        <field name="name">stock.picking.form.sudi.diamond</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_confirm']" position="attributes">
                <attribute name="invisible">state != 'draft' or (sudi_is_diamond_job_work and picking_type_code == 'incoming')</attribute>
            </xpath>

            <xpath expr="//header/button[@name='button_validate'][1]" position="attributes">
                <attribute name="invisible">state in ('sudi_pickup_pending', 'draft', 'confirmed', 'done', 'cancel') or (sudi_is_diamond_job_work and picking_type_code == 'outgoing' and sudi_origin_receipt_id)</attribute>
            </xpath>
            <xpath expr="//header/button[@name='button_validate'][2]" position="attributes">
                <attribute name="invisible">state in ('sudi_pickup_pending', 'waiting', 'assigned', 'done', 'cancel') or (sudi_is_diamond_job_work and picking_type_code == 'outgoing' and sudi_origin_receipt_id)</attribute>
            </xpath>
            <xpath expr="//header/field[@name='state'][@widget='statusbar'][1]" position="attributes">
                <attribute name="statusbar_visible">sudi_pickup_pending,draft,assigned,done</attribute>
            </xpath>

            <xpath expr="//header/button[@name='action_confirm']" position="after">
                <button name="action_confirm"
                        invisible="state != 'draft' or not sudi_is_diamond_job_work or picking_type_code != 'incoming'"
                        string="Mark READY for Job work"
                        type="object"
                        class="oe_highlight"
                        icon="fa-flag-checkered"
                        groups="stock.group_stock_user"
                        data-hotkey="q"/>
                <button name="action_sudi_confirm_pickup"
                        string="Confirm Pickup"
                        type="object"
                        icon="fa-check-square-o"
                        groups="base.group_user"
                        invisible="not sudi_is_diamond_job_work or picking_type_code != 'incoming' or state != 'sudi_pickup_pending'"/>
                <field name="sudi_display_timesheet_timer" invisible="1"/>
                <field name="sudi_total_hours_spent" invisible="1"/>
                <field name="sudi_timesheet_unit_amount" invisible="1"/>
                <button class="btn-primary"
                        name="action_timer_start"
                        type="object"
                        string="Start"
                        data-hotkey="z"
                        groups="hr_timesheet.group_hr_timesheet_user"
                        invisible="state != 'assigned' or not sudi_display_timesheet_timer or timer_start or sudi_total_hours_spent"/>
                <button class="btn-secondary"
                        name="action_timer_start"
                        type="object"
                        string="Start"
                        data-hotkey="z"
                        groups="hr_timesheet.group_hr_timesheet_user"
                        invisible="state != 'assigned' or not sudi_display_timesheet_timer or timer_start or not sudi_total_hours_spent"/>
                <button class="btn-primary o_fsm_stop"
                        name="action_timer_stop"
                        type="object"
                        string="Stop"
                        data-hotkey="z"
                        groups="hr_timesheet.group_hr_timesheet_user"
                        invisible="state != 'assigned' or not sudi_display_timesheet_timer or not timer_start"/>
                <field name="timer_start"
                       widget="timer_start_field"
                       class="d-flex align-self-center me-auto ms-2 h2"
                       options="{'unit_amount_field': 'sudi_timesheet_unit_amount'}"
                       groups="hr_timesheet.group_hr_timesheet_user"
                       invisible="state != 'assigned' or not sudi_display_timesheet_timer"/>
            </xpath>

            <xpath expr="//header/button[@name='button_validate'][1]" position="after">
                <button name="action_sudi_mark_delivered"
                        string="Mark Delivered"
                        type="object"
                        class="btn-primary"
                        icon="fa-check"
                        groups="base.group_user"
                        invisible="not sudi_is_diamond_job_work or picking_type_code != 'outgoing' or not sudi_origin_receipt_id or state in ['done', 'cancel']"/>
                <button name="action_sudi_create_invoice"
                        string="Create Diamond Invoice"
                        type="object"
                        class="btn-primary"
                        groups="account.group_account_invoice"
                        invisible="not sudi_is_diamond_job_work or state != 'done' or picking_type_code not in ['incoming', 'outgoing']"/>
                <button name="action_sudi_recompute_billing_details"
                        string="Recompute Billing Details"
                        type="object"
                        groups="stock.group_stock_manager"
                        invisible="not sudi_is_diamond_job_work or picking_type_code != 'incoming'"/>
            </xpath>

            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_sudi_view_deliveries"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-truck"
                        invisible="not sudi_is_diamond_job_work or picking_type_code != 'incoming' or sudi_delivery_count == 0">
                    <field name="sudi_delivery_count" widget="statinfo" string="Deliveries"/>
                </button>
                <button name="action_sudi_view_origin_receipt"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-sign-in"
                        invisible="not sudi_origin_receipt_id">
                    <div class="o_form_field o_stat_info">
                        <span class="o_stat_text">Receipt</span>
                    </div>
                </button>
                <button name="action_sudi_view_invoices"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-pencil-square-o"
                        invisible="not sudi_is_diamond_job_work or sudi_invoice_count == 0">
                    <field name="sudi_invoice_count" widget="statinfo" string="Invoices"/>
                </button>
            </xpath>

            <xpath expr="//field[@name='partner_id'][@nolabel='1']" position="after">
                <!-- <field name="sudi_is_diamond_job_work"/> -->
                <field name="sudi_origin_receipt_id"
                       invisible="not sudi_origin_receipt_id"
                       readonly="1"/>
                <field name="sudi_jangad_image"
                       widget="image"
                       invisible="not sudi_is_diamond_job_work"
                       readonly="state in ['cancel', 'done']"/>
            </xpath>

            <xpath expr="//field[@name='user_id']" position="after">
                <field name="sudi_is_diamond_job_work"/>
            </xpath>

            <xpath expr="//field[@name='origin']" position="after">
                <field name="sudi_pickup_user_id"
                       invisible="not sudi_is_diamond_job_work"
                       readonly="state in ['cancel', 'done']"/>
                <field name="sudi_pickup_datetime"
                       invisible="not sudi_is_diamond_job_work"
                       readonly="state in ['cancel', 'done']"/>
                <field name="sudi_customer_contact"
                       invisible="not sudi_is_diamond_job_work"
                       readonly="state in ['cancel', 'done']"/>
                <field name="sudi_pickup_address_id"
                       invisible="not sudi_is_diamond_job_work or picking_type_code != 'incoming'"
                       readonly="state in ['cancel', 'done']"
                       options="{'no_create': True}"/>
                <field name="sudi_pickup_address"
                       invisible="not sudi_is_diamond_job_work or picking_type_code != 'incoming'"
                       readonly="state in ['cancel', 'done']"
                       placeholder="Pickup address submitted from Jangad upload..."/>
                <field name="sudi_timesheet_job_type_id"
                       invisible="not sudi_is_diamond_job_work or picking_type_code != 'incoming'"
                       readonly="state in ['cancel', 'done']"
                       groups="hr_timesheet.group_hr_timesheet_user"/>
                <field name="user_id" widget="many2one_avatar_user" domain="[('share', '=', False)]" readonly="state in ['cancel', 'done']"/>
            </xpath>

            <xpath expr="//page[@name='extra']//group[@name='other_infos']" position="after">
                <group string="Diamond Job Work" name="sudi_diamond_job_work_info" invisible="not sudi_is_diamond_job_work">
                    <field name="sudi_internal_notes" nolabel="1" placeholder="Internal job-work notes..."/>
                </group>
            </xpath>

            <xpath expr="//page[@name='operations']" position="after">
                <page string="Billing Details"
                      name="sudi_billing_details"
                      groups="stock.group_stock_manager"
                      invisible="not sudi_is_diamond_job_work or picking_type_code != 'incoming'">
                    <field name="sudi_billing_line_ids" context="{'default_picking_id': id}">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="active" widget="boolean_toggle"/>
                            <field name="job_type_id"/>
                            <field name="service_product_id" readonly="1"/>
                            <field name="name"/>
                            <field name="quantity"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" column_invisible="True"/>
                            <field name="price_unit"/>
                            <field name="price_subtotal" readonly="1"/>
                            <field name="price_source" readonly="1"/>
                            <field name="manual_quantity" optional="hide"/>
                            <field name="manual_price" optional="hide"/>
                            <field name="invoice_line_id" readonly="1" optional="show"/>
                        </list>
                    </field>
                </page>
                <page string="Timesheets"
                      name="sudi_timesheets"
                      groups="hr_timesheet.group_hr_timesheet_user"
                      invisible="not sudi_is_diamond_job_work or picking_type_code != 'incoming'">
                    <field name="sudi_timesheet_ids"
                           widget="timesheets_one2many"
                           mode="list,kanban"
                           context="{'default_sudi_picking_id': id, 'default_sudi_job_type_id': sudi_timesheet_job_type_id}">
                        <list editable="top" string="Timesheet Activities" decoration-muted="readonly_timesheet == True">
                            <field name="readonly_timesheet" column_invisible="True"/>
                            <field name="is_timer_running" column_invisible="True"/>
                            <field name="timer_start" column_invisible="True"/>
                            <field name="date" readonly="readonly_timesheet or is_timer_running"/>
                            <field name="user_id" column_invisible="True"/>
                            <field name="employee_id" widget="many2one_avatar_employee" required="1" context="{'active_test': True}" readonly="readonly_timesheet or is_timer_running"/>
                            <field name="sudi_job_type_id" required="1" readonly="readonly_timesheet or is_timer_running"/>
                            <field name="name" required="0" readonly="readonly_timesheet"/>
                            <field name="unit_amount" string="Time Spent" widget="timesheet_uom_timer" decoration-danger="unit_amount &gt; 24 or unit_amount &lt; 0" readonly="id and (readonly_timesheet or is_timer_running)"/>
                            <field name="project_id" column_invisible="True"/>
                            <field name="task_id" column_invisible="True"/>
                            <field name="company_id" column_invisible="True"/>
                        </list>
                        <kanban class="o_kanban_mobile">
                            <templates>
                                <t t-name="card" class="row g-0">
                                    <field name="employee_id" class="col-6 fw-bolder" context="{'active_test': True}"/>
                                    <field name="date" class="col-6 text-end fw-bolder"/>
                                    <field name="sudi_job_type_id" class="col-6 text-muted"/>
                                    <field name="unit_amount" widget="float_time" decoration-danger="unit_amount &gt; 24" class="col-6 text-end"/>
                                    <field name="name" class="col-12 text-muted"/>
                                </t>
                            </templates>
                        </kanban>
                    </field>
                    <group>
                        <group class="oe_subtotal_footer" name="sudi_receipt_hours">
                            <label class="fw-bold" for="sudi_total_hours_spent" string="Time Spent"/>
                            <field name="sudi_total_hours_spent" widget="timesheet_uom" nolabel="1"/>
                        </group>
                    </group>
                </page>
            </xpath>

            <xpath expr="//field[@name='move_ids']/list/field[@name='product_id']" position="before">
                <field name="sudi_sr" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='move_ids']/list/field[@name='description_picking']" position="after">
                <field name="sudi_size" optional="show"/>
                <field name="sudi_pcs_qty" optional="show"/>
                <field name="sudi_carats" optional="show"/>
                <field name="sudi_job_type_id" optional="show"/>
                <field name="sudi_remarks" optional="show"/>
                <field name="sudi_origin_receipt_move_id" column_invisible="True"/>
                <field name="sudi_invoice_line_id" column_invisible="True"/>
            </xpath>
            <xpath expr="//field[@name='move_ids']/list/field[@name='product_uom_qty']" position="attributes">
                <attribute name="optional">show</attribute>
            </xpath>
            <xpath expr="//field[@name='move_ids']/list/field[@name='quantity']" position="attributes">
                <attribute name="optional">show</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_picking_list_sudi_diamond" model="ir.ui.view">
        <field name="name">stock.picking.list.sudi.diamond</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.vpicktree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="default_order">create_date desc, id desc</attribute>
            </xpath>
            <xpath expr="/list//field[@name='partner_id']" position="attributes">
                <attribute name="string">Party Name/Company</attribute>
            </xpath>
            <field name="partner_id" position="after">
                <field name="sudi_is_diamond_job_work" optional="hide"/>
            </field>
        </field>
    </record>

    <record id="view_sudi_operator_pickup_list" model="ir.ui.view">
        <field name="name">stock.picking.list.sudi.operator.pickup</field>
        <field name="model">stock.picking</field>
        <field name="arch" type="xml">
            <list string="Pickup" create="0" delete="0" edit="0" default_order="create_date desc, id desc">
                <field name="name"/>
                <field name="partner_id" string="Customer" options="{'no_open': True, 'no_create': True}"/>
                <field name="sudi_customer_contact"/>
                <field name="sudi_pickup_address" string="Pickup Address"/>
                <field name="scheduled_date"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'sudi_pickup_pending'"
                       decoration-success="state == 'done'"
                       decoration-muted="state in ['draft', 'cancel']"/>
            </list>
        </field>
    </record>

    <record id="view_sudi_operator_pickup_form" model="ir.ui.view">
        <field name="name">stock.picking.form.sudi.operator.pickup</field>
        <field name="model">stock.picking</field>
        <field name="arch" type="xml">
            <form string="Pickup" create="0" delete="0">
                <header>
                    <button name="action_sudi_confirm_pickup"
                            string="Confirm Pickup"
                            type="object"
                            class="btn-primary"
                            groups="base.group_user"
                            invisible="state != 'sudi_pickup_pending'"/>
                    <field name="state" widget="statusbar" statusbar_visible="sudi_pickup_pending,draft,assigned,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="partner_id"
                                   string="Customer"
                                   readonly="1"
                                   options="{'no_open': True, 'no_create': True}"/>
                            <field name="sudi_pickup_address_id"
                                   readonly="1"
                                   options="{'no_open': True, 'no_create': True}"/>
                            <field name="sudi_pickup_address"
                                   readonly="1"
                                   nolabel="1"
                                   placeholder="No pickup address available."/>
                        </group>
                        <group>
                            <field name="scheduled_date" readonly="1"/>
                            <field name="sudi_customer_contact" readonly="1"/>
                            <field name="sudi_pickup_user_id" readonly="1"/>
                            <field name="sudi_pickup_datetime" readonly="1"/>
                        </group>
                    </group>
                    <group string="Jangad">
                        <field name="sudi_jangad_image" widget="image" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sudi_operator_delivery_list" model="ir.ui.view">
        <field name="name">stock.picking.list.sudi.operator.delivery</field>
        <field name="model">stock.picking</field>
        <field name="arch" type="xml">
            <list string="Deliveries" create="0" delete="0" edit="0" default_order="state, scheduled_date, id">
                <field name="name"/>
                <field name="partner_id" string="Customer" options="{'no_open': True, 'no_create': True}"/>
                <field name="sudi_origin_receipt_name"/>
                <field name="scheduled_date"/>
                <field name="date_done"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'assigned'"
                       decoration-warning="state not in ['assigned', 'done', 'cancel']"
                       decoration-success="state == 'done'"
                       decoration-muted="state == 'cancel'"/>
            </list>
        </field>
    </record>

    <record id="view_sudi_operator_delivery_form" model="ir.ui.view">
        <field name="name">stock.picking.form.sudi.operator.delivery</field>
        <field name="model">stock.picking</field>
        <field name="arch" type="xml">
            <form string="Deliveries" create="0" delete="0">
                <header>
                    <button name="action_sudi_mark_delivered"
                            string="Mark Delivered"
                            type="object"
                            class="btn-primary"
                            groups="base.group_user"
                            invisible="state in ['done', 'cancel']"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,assigned,done"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="partner_id"
                                   string="Customer"
                                   readonly="1"
                                   options="{'no_open': True, 'no_create': True}"/>
                            <field name="sudi_partner_address" readonly="1" nolabel="1" placeholder="No customer address available."/>
                        </group>
                        <group>
                            <field name="sudi_origin_receipt_name" readonly="1"/>
                            <field name="scheduled_date" readonly="1"/>
                            <field name="date_done" readonly="1"/>
                            <field name="sudi_pickup_user_id" readonly="1"/>
                            <field name="sudi_pickup_datetime" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Items" name="items">
                            <field name="move_ids" readonly="1">
                                <list create="0" delete="0" edit="0">
                                    <field name="sudi_sr"/>
                                    <field name="product_id"/>
                                    <field name="sudi_size"/>
                                    <field name="sudi_pcs_qty"/>
                                    <field name="sudi_carats"/>
                                    <field name="sudi_job_type_id"/>
                                    <field name="sudi_remarks"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sudi_operator_pickups" model="ir.actions.act_window">
        <field name="name">Pickup</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_sudi_operator_pickup_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_sudi_operator_pickup_form')})]"/>
        <field name="domain">[
            ('sudi_is_diamond_job_work', '=', True),
            ('picking_type_id.code', '=', 'incoming'),
            ('state', '=', 'sudi_pickup_pending'),
        ]</field>
        <field name="context">{'create': False, 'delete': False}</field>
    </record>

    <record id="action_sudi_operator_deliveries" model="ir.actions.act_window">
        <field name="name">Deliveries</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_sudi_operator_delivery_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_sudi_operator_delivery_form')})]"/>
        <field name="domain">[
            ('sudi_is_diamond_job_work', '=', True),
            ('picking_type_id.code', '=', 'outgoing'),
            ('sudi_origin_receipt_id', '!=', False),
        ]</field>
        <field name="context">{'create': False, 'delete': False}</field>
    </record>

    <record id="action_sudi_diamond_receipts" model="ir.actions.act_window">
        <field name="name">Diamond Job Work Receipts</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,kanban,form,calendar,activity</field>
        <field name="domain">[('sudi_is_diamond_job_work', '=', True), ('picking_type_id.code', '=', 'incoming')]</field>
        <field name="context">{'default_sudi_is_diamond_job_work': True, 'restricted_picking_type_code': 'incoming'}</field>
    </record>

    <record id="action_sudi_diamond_deliveries" model="ir.actions.act_window">
        <field name="name">Diamond Job Work Deliveries</field>
        <field name="res_model">stock.picking</field>
        <field name="view_mode">list,kanban,form,calendar,activity</field>
        <field name="domain">[('sudi_is_diamond_job_work', '=', True), ('picking_type_id.code', '=', 'outgoing')]</field>
        <field name="context">{'default_sudi_is_diamond_job_work': True, 'restricted_picking_type_code': 'outgoing'}</field>
    </record>
</odoo>
