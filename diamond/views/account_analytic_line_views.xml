<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_timesheet_line_tree_sudi_diamond" model="ir.ui.view">
        <field name="name">account.analytic.line.list.sudi.diamond</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="hr_timesheet.hr_timesheet_line_tree"/>
        <field name="arch" type="xml">
            <field name="task_id" position="after">
                <field name="sudi_picking_id" optional="show"/>
                <field name="sudi_job_type_id" optional="show"/>
            </field>
        </field>
    </record>

    <record id="hr_timesheet_line_form_sudi_diamond" model="ir.ui.view">
        <field name="name">account.analytic.line.form.sudi.diamond</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="hr_timesheet.hr_timesheet_line_form"/>
        <field name="arch" type="xml">
            <field name="task_id" position="after">
                <field name="sudi_picking_id" readonly="readonly_timesheet"/>
                <field name="sudi_job_type_id" readonly="readonly_timesheet"/>
            </field>
        </field>
    </record>

    <record id="hr_timesheet_line_search_sudi_diamond" model="ir.ui.view">
        <field name="name">account.analytic.line.search.sudi.diamond</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="hr_timesheet.hr_timesheet_line_search"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='groupby']" position="before">
                <field name="sudi_picking_id"/>
                <field name="sudi_job_type_id"/>
            </xpath>
            <xpath expr="//group[@name='groupby']" position="inside">
                <filter string="Receipt" name="groupby_sudi_picking" domain="[]" context="{'group_by': 'sudi_picking_id'}"/>
                <filter string="Job Type" name="groupby_sudi_job_type" domain="[]" context="{'group_by': 'sudi_job_type_id'}"/>
            </xpath>
        </field>
    </record>

    <record id="view_hr_timesheet_line_pivot_sudi_diamond" model="ir.ui.view">
        <field name="name">account.analytic.line.pivot.sudi.diamond</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="hr_timesheet.view_hr_timesheet_line_pivot"/>
        <field name="arch" type="xml">
            <field name="employee_id" position="after">
                <field name="sudi_picking_id" type="row"/>
                <field name="sudi_job_type_id" type="row"/>
            </field>
        </field>
    </record>

    <record id="view_hr_timesheet_line_graph_all_sudi_diamond" model="ir.ui.view">
        <field name="name">account.analytic.line.graph.sudi.diamond</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="hr_timesheet.view_hr_timesheet_line_graph_all"/>
        <field name="arch" type="xml">
            <field name="employee_id" position="after">
                <field name="sudi_picking_id"/>
                <field name="sudi_job_type_id"/>
            </field>
        </field>
    </record>
</odoo>
