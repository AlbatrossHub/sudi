<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_sudi_diamond" model="ir.ui.view">
        <field name="name">account.move.form.sudi.diamond</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_sudi_view_receipt"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-sign-in"
                        invisible="not sudi_receipt_id">
                    <div class="o_form_field o_stat_info">
                        <span class="o_stat_text">Receipt</span>
                    </div>
                </button>
                <button name="action_sudi_view_deliveries"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-truck"
                        invisible="sudi_delivery_count == 0">
                    <field name="sudi_delivery_count" widget="statinfo" string="Deliveries"/>
                </button>
            </xpath>

            <xpath expr="//field[@name='invoice_origin']" position="after">
                <field name="sudi_is_diamond_job_work_invoice" invisible="1"/>
                <field name="sudi_receipt_id" readonly="1" invisible="not sudi_is_diamond_job_work_invoice"/>
                <field name="sudi_delivery_ids" widget="many2many_tags" readonly="1" invisible="not sudi_is_diamond_job_work_invoice"/>
            </xpath>

            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='name']" position="after">
                <field name="sudi_stock_move_id" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="action_sudi_diamond_invoices" model="ir.actions.act_window">
        <field name="name">Diamond Job Work Invoices</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,kanban,form,activity</field>
        <field name="domain">[('sudi_is_diamond_job_work_invoice', '=', True), ('move_type', '=', 'out_invoice')]</field>
        <field name="context">{'default_move_type': 'out_invoice', 'default_sudi_is_diamond_job_work_invoice': True}</field>
    </record>
</odoo>
