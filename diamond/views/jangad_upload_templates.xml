<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="jangad_pwa_head" name="Jangad PWA Head">
        <link rel="manifest" href="/jangad/manifest.webmanifest"/>
        <link rel="apple-touch-icon" href="/jangad/icon/192.png?v=2"/>
        <meta name="theme-color" content="#875A7B"/>
        <meta name="apple-mobile-web-app-capable" content="yes"/>
        <meta name="apple-mobile-web-app-title" content="Jangad"/>
        <meta name="mobile-web-app-capable" content="yes"/>
        <meta name="application-name" content="Jangad"/>
    </template>

    <template id="jangad_upload_form" name="Jangad Upload">
        <t t-call="website.layout">
            <t t-set="head">
                <t t-out="head"/>
                <t t-call="diamond.jangad_pwa_head"/>
            </t>
            <div id="wrap" class="oe_structure">
                <section class="container py-5">
                    <div class="row justify-content-center">
                        <div class="col-lg-6">
                            <h1 class="mb-3">Upload Jangad</h1>
                            <p class="text-muted">
                                Please enter your phone number and upload the Jangad image.
                            </p>
                            <div t-if="error" class="alert alert-danger" role="alert">
                                <t t-out="error"/>
                            </div>
                            <div class="alert alert-danger d-none" data-sudi-jangad-error="" role="alert"></div>
                            <div class="alert alert-success d-none" data-sudi-jangad-success="" role="alert"></div>
                            <div class="alert alert-info d-none" data-sudi-jangad-pending="" role="alert"></div>
                            <form action="/jangad"
                                  method="post"
                                  enctype="multipart/form-data"
                                  class="card p-4"
                                  data-sudi-jangad-upload="1"
                                  data-json-url="/jangad/json"
                                  data-address-url="/jangad/address_suggestions"
                                  t-att-data-initial-addresses="address_suggestions_json">
                                <input type="hidden" name="csrf_token" t-att-value="csrf_token"/>
                                <div class="mb-3">
                                    <label for="sudi_jangad_phone" class="form-label">Phone Number</label>
                                    <input id="sudi_jangad_phone"
                                           type="tel"
                                           name="phone"
                                           class="form-control"
                                           required="required"
                                           t-att-value="phone"/>
                                </div>
                                <div class="mb-3" data-sudi-pickup-address="">
                                    <label class="form-label">Pickup Address</label>
                                    <input type="hidden"
                                           name="pickup_address_id"
                                           data-sudi-pickup-address-id=""
                                           t-att-value="pickup_address_id"/>
                                    <input type="hidden"
                                           name="pickup_address_mode"
                                           data-sudi-pickup-address-mode=""
                                           t-att-value="pickup_address_mode"/>
                                    <div class="small text-muted mb-2" data-sudi-pickup-address-status="">
                                        Enter a 10-digit phone number to search pickup addresses.
                                    </div>
                                    <div class="list-group mb-2 d-none" data-sudi-pickup-address-options=""></div>
                                    <button type="button"
                                            class="btn btn-link p-0 mb-2"
                                            data-sudi-pickup-address-manual-button="">
                                        Enter a new pickup address
                                    </button>
                                    <div t-att-class="'d-none' if pickup_address_mode != 'manual' else ''"
                                         data-sudi-pickup-address-manual-wrap="">
                                        <textarea name="manual_pickup_address"
                                                  class="form-control"
                                                  rows="3"
                                                  placeholder="Enter full pickup address"
                                                  data-sudi-pickup-address-manual=""><t t-out="manual_pickup_address"/></textarea>
                                        <div class="form-text">
                                            This address will be saved as a child pickup address for future use.
                                        </div>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label for="sudi_jangad_image" class="form-label">Jangad Image</label>
                                    <input id="sudi_jangad_image"
                                           type="file"
                                           name="jangad_image"
                                           class="form-control"
                                           accept="image/*"
                                           capture="environment"
                                           required="required"/>
<!--                                     <div class="form-text">
                                        On mobile, this can open the camera. The image will be compressed before upload when supported.
                                    </div> -->
                                    <div class="small text-muted mt-2" data-sudi-jangad-size=""></div>
                                </div>
                                <div class="progress mb-3 d-none" data-sudi-jangad-progress-wrap="">
                                    <div class="progress-bar" data-sudi-jangad-progress="" role="progressbar" style="width: 0%">0%</div>
                                </div>
                                <div class="d-flex gap-2">
                                    <button type="submit" class="btn btn-primary" data-sudi-jangad-submit="">Submit</button>
                                    <button type="button" class="btn btn-outline-secondary d-none" data-sudi-jangad-retry="">
                                        Retry Pending Uploads
                                    </button>
                                </div>
                                <p class="text-muted small mt-3 mb-0">
                                    If the network is weak, the compressed image can be saved on this device and retried when online.
                                </p>
                            </form>
                            <div class="card p-4 text-center d-none" data-sudi-jangad-complete="">
                                <div class="alert alert-success" role="alert" data-sudi-jangad-complete-message="">
                                    Your Jangad image has been submitted successfully.
                                </div>
                                <button type="button" class="btn btn-primary" data-sudi-jangad-submit-another="">
                                    Submit Another Jangad
                                </button>
                            </div>
                            <div data-sudi-jangad-pwa="1">
                                <div class="alert alert-light border sudi-jangad-pwa-banner d-none" data-sudi-jangad-pwa-android="">
                                    <button type="button" class="btn-close" aria-label="Close" data-sudi-jangad-pwa-dismiss=""></button>
                                    <h5 class="mb-2">Install Jangad Upload</h5>
                                    <p class="mb-3">Install this page as an app for quick camera uploads.</p>
                                    <button type="button" class="btn btn-primary" data-sudi-jangad-pwa-install="">Install App</button>
                                </div>
                                <div class="alert alert-light border sudi-jangad-pwa-banner d-none" data-sudi-jangad-pwa-ios="">
                                    <button type="button" class="btn-close" aria-label="Close" data-sudi-jangad-pwa-dismiss=""></button>
                                    <h5 class="mb-2">Install on iPhone or iPad</h5>
                                    <ol class="mb-0 ps-3">
                                        <li>Open this page in Safari.</li>
                                        <li>Tap the Share button.</li>
                                        <li>Choose Add to Home Screen.</li>
                                        <li>Tap Add.</li>
                                    </ol>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <template id="jangad_upload_success" name="Jangad Upload Success">
        <t t-call="website.layout">
            <t t-set="head">
                <t t-out="head"/>
                <t t-call="diamond.jangad_pwa_head"/>
            </t>
            <div id="wrap" class="oe_structure">
                <section class="container py-5">
                    <div class="row justify-content-center">
                        <div class="col-lg-6">
                            <div class="alert alert-success" role="alert">
                                Your Jangad image has been submitted successfully.
                            </div>
                            <p>
                                Receipt reference:
                                <strong>
                                    <t t-out="receipt.name"/>
                                </strong>
                            </p>
                            <p t-if="not partner_found" class="text-muted">
                                We could not match your phone number with an existing customer.
                                Our team will review it from the receipt contact field.
                            </p>
                            <a href="/jangad" class="btn btn-primary">Submit Another Jangad</a>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <template id="jangad_upload_offline" name="Jangad Upload Offline">
        <t t-call="website.layout">
            <t t-set="head">
                <t t-out="head"/>
                <t t-call="diamond.jangad_pwa_head"/>
            </t>
            <div id="wrap" class="oe_structure">
                <section class="container py-5">
                    <div class="row justify-content-center">
                        <div class="col-lg-6">
                            <div class="alert alert-warning" role="alert">
                                You are offline. Reopen Jangad Upload when the network is available.
                            </div>
                            <a href="/jangad" class="btn btn-primary">Open Jangad Upload</a>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <template id="jangad_upload_qr" name="Jangad Upload QR">
        <t t-call="website.layout">
            <t t-set="head">
                <t t-out="head"/>
                <t t-call="diamond.jangad_pwa_head"/>
            </t>
            <div id="wrap" class="oe_structure">
                <section class="container py-5">
                    <div class="row justify-content-center">
                        <div class="col-lg-6 text-center">
                            <div class="card p-4 sudi-jangad-qr-card">
                                <h1 class="h3 mb-3">Install Jangad Upload</h1>
                                <p class="text-muted">Scan this QR code to open the installable upload page.</p>
                                <img t-att-src="qr_src" alt="Jangad Upload QR Code" class="mx-auto mb-3"/>
                                <p class="small text-break mb-3">
                                    <a t-att-href="upload_url">
                                        <t t-out="upload_url"/>
                                    </a>
                                </p>
                                <a t-att-href="upload_url" class="btn btn-primary">Open Upload Page</a>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>
