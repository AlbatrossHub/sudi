<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_diamond_job_work" model="ir.actions.report">
        <field name="name">Diamond Job Work Receipt / Delivery</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">diamond.report_diamond_job_work_document</field>
        <field name="report_file">diamond.report_diamond_job_work_document</field>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_diamond_job_work_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>
                            <span t-if="o.picking_type_code == 'incoming'">Diamond Job Work Receipt</span>
                            <span t-elif="o.picking_type_code == 'outgoing'">Diamond Job Work Delivery</span>
                            <span t-else="">Diamond Job Work Transfer</span>
                        </h2>

                        <div class="row mb-3">
                            <div class="col-6">
                                <strong>Transfer:</strong>
                                <span t-field="o.name"/>
                                <br/>
                                <strong>Customer:</strong>
                                <span t-field="o.partner_id"/>
                                <br/>
                                <strong>Source:</strong>
                                <span t-field="o.origin"/>
                            </div>
                            <div class="col-6">
                                <strong>Scheduled Date:</strong>
                                <span t-field="o.scheduled_date"/>
                                <br/>
                                <strong>Pickup Person:</strong>
                                <span t-field="o.sudi_pickup_user_id"/>
                                <br/>
                                <strong>Pickup Date/Time:</strong>
                                <span t-field="o.sudi_pickup_datetime"/>
                            </div>
                        </div>

                        <table class="table table-sm o_main_table">
                            <thead>
                                <tr>
                                    <th>Sr</th>
                                    <th>Product / Description</th>
                                    <th>Size</th>
                                    <th class="text-end">Pcs / Qty</th>
                                    <th class="text-end">Carats</th>
                                    <th>Job Type</th>
                                    <th>Remarks</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.move_ids.filtered(lambda m: m.state != 'cancel')" t-as="move">
                                    <td>
                                        <span t-field="move.sudi_sr"/>
                                    </td>
                                    <td>
                                        <span t-field="move.product_id"/>
                                        <p t-if="move.description_picking">
                                            <span t-field="move.description_picking"/>
                                        </p>
                                    </td>
                                    <td>
                                        <span t-field="move.sudi_size"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-field="move.sudi_pcs_qty"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-field="move.sudi_carats"/>
                                    </td>
                                    <td>
                                        <span t-field="move.sudi_job_type_id"/>
                                    </td>
                                    <td>
                                        <span t-field="move.sudi_remarks"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <div t-if="o.sudi_internal_notes" class="mt-3">
                            <strong>Notes:</strong>
                            <p t-field="o.sudi_internal_notes"/>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
